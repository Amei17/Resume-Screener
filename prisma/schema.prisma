generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Candidate {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resumes   Resume[]
}

model Resume {
  id           String        @id @default(cuid())
  fileName     String
  fileData     String
  extractedText String?
  candidateId  String?
  candidate    Candidate?    @relation(fields: [candidateId], references: [id])
  parsedEntities ParsedEntity[]
  skills       Skill[]
  screeningResults ScreeningResult[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ParsedEntity {
  id        String   @id @default(cuid())
  type      String   // "name", "email", "phone", "education", "experience", etc.
  value     String
  confidence Float?
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id])
  createdAt DateTime @default(now())
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  category  String?  // "technical", "soft", "tool", etc.
  matched   Boolean  @default(false)
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id])
  createdAt DateTime @default(now())
}

model ScreeningResult {
  id                  String            @id @default(cuid())
  inputHash           String            @unique
  overallMatchScore   Int
  recommendation      String            // "Strong Hire", "Hire", "Maybe", "Reject"
  strengths           String            // JSON array as string
  weaknesses          String            // JSON array as string
  inconsistencies     String            // JSON array as string
  skillsMatched       String            // JSON array as string
  missingSkills       String            // JSON array as string
  jobDescriptionId    String?
  resumeId            String
  resume              Resume            @relation(fields: [resumeId], references: [id])
  screeningReasons    ScreeningReason[]
  flags               Flag[]
  createdAt           DateTime          @default(now())
}

model ScreeningReason {
  id         String   @id @default(cuid())
  category   String   // "skills", "experience", "education", etc.
  score      Int
  reason     String
  resultId   String
  result     ScreeningResult @relation(fields: [resultId], references: [id])
  createdAt  DateTime @default(now())
}

model Flag {
  id          String   @id @default(cuid())
  type        String   // "employment_gap", "education_mismatch", "short_tenure", etc.
  description String
  severity    String   // "low", "medium", "high"
  resultId    String
  result      ScreeningResult @relation(fields: [resultId], references: [id])
  createdAt   DateTime @default(now())
}
